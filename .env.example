# Recon Configuration Template
# Copy this file to '.env' in the same folder and add your tokens/keys:
# cp .env.example .env

# OpenRouter configuration (hosts DeepSeek V3, Claude, Gemini, etc.)
OPENROUTER_API_KEY="your-openrouter-token-here"

# Default model to use in run_comparative_benchmark if not explicitly passed
RECON_MODEL="deepseek/deepseek-chat"

# Alternative official endpoints
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
